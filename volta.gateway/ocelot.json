{
    "Routes": [
        // --- 1. AUTH SERVICE (Port 5001) ---
        // Maps localhost:5000/api/auth/... -> localhost:5001/api/auth/...
        {
            "DownstreamPathTemplate": "/api/auth/{everything}",
            "DownstreamScheme": "http",
            "DownstreamHostAndPorts": [
                {
                    "Host": "localhost",
                    "Port": 5001
                }
            ],
            "UpstreamPathTemplate": "/api/auth/{everything}",
            "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ]
        },

        // --- 2. RIDE SERVICE (Port 5002) ---
        // Maps localhost:5000/ride/... -> localhost:5002/ride/...
        {
            "DownstreamPathTemplate": "/ride/{everything}",
            "DownstreamScheme": "http",
            "DownstreamHostAndPorts": [
                {
                    "Host": "localhost",
                    "Port": 5002
                }
            ],
            "UpstreamPathTemplate": "/ride/{everything}",
            "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ]
        },

        // --- 3. DRIVER SERVICE (Port 5004) ---
        // Maps localhost:5000/driver/... -> localhost:5004/api/driver/...
        {
            "DownstreamPathTemplate": "/api/driver/{everything}",
            "DownstreamScheme": "http",
            "DownstreamHostAndPorts": [
                {
                    "Host": "localhost",
                    "Port": 5004
                }
            ],
            "UpstreamPathTemplate": "/driver/{everything}",
            "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ]
        }
    ],
    "GlobalConfiguration": {
        "BaseUrl": "http://localhost:5000"
    }
}