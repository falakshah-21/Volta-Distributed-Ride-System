@page "/404"
@inject NavigationManager Nav

<div class="volta-404-wrapper">
    <div class="lost-container fade-in-up">

        <div class="svg-container mb-4">
            <svg class="compass-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path class="compass-ring" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path>
                <path class="compass-needle" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M12 6l-2 6 2 6 2-6-2-6z"></path>
            </svg>
            <div class="error-badge pulse-error">404</div>
        </div>

        <h1 class="fw-bold text-dark m-0">Dead End!</h1>
        <p class="text-muted mt-2 mb-4" style="font-size: 1.1rem; line-height: 1.5;">
            Looks like your GPS signal dropped. The route you're trying to take doesn't exist on our map.
        </p>

        <button class="btn-reroute" @onclick="Reroute">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"></path>
            </svg>
            Reroute to Dashboard
        </button>

    </div>
</div>

@code {
    private void Reroute()
    {
        Nav.NavigateTo("/");
    }
}