@page "/login"
@layout Volta.Client.Layout.AuthLayout
@inject HttpClient Http
@inject NavigationManager Nav
@using System.Net.Http.Json
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage

<div class="card shadow-lg border-0 p-5" style="width: 100%; max-width: 400px; border-radius: 16px;">
    <div class="text-center mb-4">
        <h2 class="fw-bold" style="color: #3f51b5;">Welcome Back</h2>
        <p class="text-muted">Login to access your dashboard</p>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger text-center small">@errorMessage</div>
    }

    <div class="mb-3">
        <label class="fw-bold small text-muted">USERNAME</label>
        <input @bind="loginModel.Username" class="form-control form-control-lg" placeholder="Enter Username" />
    </div>

    <div class="mb-4">
        <label class="fw-bold small text-muted">PASSWORD</label>
        <div class="input-group">
            <input @bind="loginModel.Password" type="@(showPassword ? "text" : "password")" class="form-control form-control-lg" placeholder="••••••" />
            <button class="btn btn-outline-secondary" type="button" @onclick="() => showPassword = !showPassword">
                @(showPassword ? "🙈" : "👁️")
            </button>
        </div>
    </div>

    <button class="btn btn-primary btn-lg w-100 mb-3" @onclick="HandleLogin">Login</button>

    <div class="text-center">
        <small class="text-muted">Don't have an account? <a href="/register" class="fw-bold" style="color: #3f51b5;">Sign Up</a></small>
    </div>
</div>

@code {
    private LoginRequest loginModel = new LoginRequest();
    private string errorMessage;
    private bool showPassword = false;

    private async Task HandleLogin()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("http://localhost:5001/api/auth/login", loginModel);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
                await SessionStorage.SetItemAsync("authToken", result.Token);
                await SessionStorage.SetItemAsync("userRole", result.Role);

                // Force Refresh to ensure the MainLayout loads correctly
                Nav.NavigateTo("/", forceLoad: true);
            }
            else
            {
                // Read the error message from the API if possible, otherwise generic message
                var errorContent = await response.Content.ReadAsStringAsync();
                errorMessage = !string.IsNullOrEmpty(errorContent) ? errorContent : "Invalid Username or Password";

                // Handle the specific "Account Pending" 401 case
                if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized && errorContent.Contains("Pending"))
                {
                    errorMessage = "⛔ Account Pending! An Admin must approve you first.";
                }
            }
        }
        catch (Exception ex) { errorMessage = "Server Error: " + ex.Message; }
    }

    public class LoginRequest { public string Username { get; set; } public string Password { get; set; } }
    public class LoginResponse { public string Token { get; set; } public string Role { get; set; } }
}