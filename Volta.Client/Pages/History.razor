@page "/history"
@inject HttpClient Http
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@using System.Net.Http.Json
@using System.Net.Http.Headers

<div class="container mt-4" style="max-width: 900px;">
    <div class="card shadow border-0" style="border-radius: 12px; overflow: hidden;">

        <div class="card-header bg-volta text-white d-flex justify-content-between align-items-center py-3 px-4">
            <h4 class="mb-0 fw-bold">📜 Ride History</h4>
            <button class="btn btn-sm btn-light text-primary fw-bold" @onclick="LoadHistory">🔄 Refresh</button>
        </div>

        <div class="card-body p-0">
            @if (isLoading)
            {
                <div class="text-center p-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">Loading your trips...</p>
                </div>
            }
            else if (rides.Count == 0)
            {
                <div class="text-center p-5">
                    <h3 class="text-muted opacity-50">📭</h3>
                    <h5 class="fw-bold text-muted">No History Found</h5>
                    <p class="text-muted small">You haven't taken any rides yet.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="ps-4 py-3">Ref #</th>
                                <th>Route</th>
                                <th>Driver</th>
                                <th>Price</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ride in rides)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-muted">#@ride.Id</td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold text-dark">@ride.PickupLocation</span>
                                            <small class="text-muted">to @ride.DropoffLocation</small>
                                        </div>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(ride.DriverName))
                                        {
                                            <span class="d-flex align-items-center gap-2">
                                                <span class="bg-light rounded-circle p-1">🚘</span> @ride.DriverName
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">--</span>
                                        }
                                    </td>
                                    <td class="fw-bold">Rs. @ride.Price</td>
                                    <td>
                                        @if (ride.Status == "Completed")
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success px-3 py-2 rounded-pill">Completed</span>
                                        }
                                        else if (ride.Status == "Canceled")
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-3 py-2 rounded-pill">Canceled</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning bg-opacity-10 text-warning border border-warning px-3 py-2 rounded-pill">@ride.Status</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<RideHistoryDto> rides = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadHistory();
    }

    private async Task LoadHistory()
    {
        isLoading = true;
        try
        {
            var token = await SessionStorage.GetItemAsync<string>("authToken");
            if (string.IsNullOrEmpty(token)) return;

            var request = new HttpRequestMessage(HttpMethod.Get, "http://localhost:5002/ride/history");
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                rides = await response.Content.ReadFromJsonAsync<List<RideHistoryDto>>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading history: " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    public class RideHistoryDto
    {
        public int Id { get; set; }
        public string PickupLocation { get; set; }
        public string DropoffLocation { get; set; }
        public decimal Price { get; set; }
        public string Status { get; set; }
        public string? DriverName { get; set; }
    }
}