@page "/book"
@inject HttpClient Http
@inject NavigationManager Nav
@using System.Net.Http.Json
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@using System.Net.Http.Headers
@inject IJSRuntime JSRuntime

<div class="container-fluid p-0" style="height: calc(100vh - 60px);">
    <div class="row h-100 g-0">

        <div class="col-md-4 col-lg-3 bg-white shadow-lg p-4 d-flex flex-column z-index-10">
            <h4 class="fw-bold mb-4" style="color: #1e1e2f;">🚗 Book a Ride</h4>

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="alert alert-info small text-center">@statusMessage</div>
            }

            <div class="btn-group w-100 mb-3">
                <button class="btn @(selectingPickup ? "btn-success" : "btn-outline-secondary")" @onclick="() => selectingPickup = true">📍 Pickup</button>
                <button class="btn @(!selectingPickup ? "btn-danger" : "btn-outline-secondary")" @onclick="() => selectingPickup = false">🏁 Dropoff</button>
            </div>

            <div class="mb-3">
                <label class="fw-bold small text-muted">PICKUP LOCATION</label>
                <div class="input-group">
                    <input @bind="rideRequest.PickupLocation" class="form-control" placeholder="Search (e.g. Lucky One)..." />
                    <button class="btn btn-outline-primary" @onclick="() => SearchMap(true)">🔍</button>
                </div>
            </div>

            <div class="mb-3">
                <label class="fw-bold small text-muted">DROPOFF LOCATION</label>
                <div class="input-group">
                    <input @bind="rideRequest.DropoffLocation" class="form-control" placeholder="Search (e.g. KIET)..." />
                    <button class="btn btn-outline-danger" @onclick="() => SearchMap(false)">🔍</button>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(etaText))
            {
                <div class="alert alert-success d-flex justify-content-between align-items-center shadow-sm">
                    <div>
                        <small class="text-muted fw-bold d-block">ESTIMATED TIME</small>
                        <span class="fs-4 fw-bold">⏱️ @etaText</span>
                    </div>
                    <div class="text-end">
                        <small class="text-muted fw-bold d-block">DISTANCE</small>
                        <span class="fs-5">📏 @distanceText</span>
                    </div>
                </div>
            }

            <div class="mb-4">
                <label class="fw-bold small text-muted">OFFER PRICE (PKR)</label>
                <input @bind="rideRequest.Price" type="number" class="form-control fw-bold" placeholder="500" />
            </div>

            <button class="btn btn-primary w-100 py-2 mt-auto" style="background: linear-gradient(135deg, #1e1e2f 0%, #3f51b5 100%); border:none;" @onclick="BookNow">Request Ride</button>
            <button class="btn btn-link text-muted w-100 mt-2" @onclick='() => Nav.NavigateTo("/")'>Cancel</button>
        </div>

        <div class="col-md-8 col-lg-9 position-relative">
            <div id="map" style="height: 100%; width: 100%; min-height: 500px; background-color: #eee;"></div>
        </div>
    </div>
</div>

@code {
    private RideRequest rideRequest = new RideRequest();
    private string statusMessage;
    private bool selectingPickup = true;

    // 🆕 Track Coordinates for Routing
    private double? pickLat, pickLng, dropLat, dropLng;
    private string etaText = "";
    private string distanceText = "";

    // 1. INIT MAP
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var dotNetReference = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("voltaMap.initMap", "map", dotNetReference);
        }
    }

    // 2. SEARCH BUTTON CLICKED
    private async Task SearchMap(bool isPickup)
    {
        string query = isPickup ? rideRequest.PickupLocation : rideRequest.DropoffLocation;
        if (string.IsNullOrEmpty(query)) return;

        statusMessage = "🔍 Searching...";

        // We now get the "lat,lng" string back from JS
        string coords = await JSRuntime.InvokeAsync<string>("voltaMap.searchLocation", query, isPickup);

        if (!string.IsNullOrEmpty(coords))
        {
            var parts = coords.Split(',');
            if (isPickup) { pickLat = double.Parse(parts[0]); pickLng = double.Parse(parts[1]); }
            else { dropLat = double.Parse(parts[0]); dropLng = double.Parse(parts[1]); }

            // Trigger Route Calculation
            await CheckRoute();
        }
        statusMessage = "";
    }

    // 3. MAP CLICKED
    [JSInvokable]
    public async Task OnMapClicked(double lat, double lng, string address)
    {
        if (selectingPickup)
        {
            rideRequest.PickupLocation = address;
            pickLat = lat; pickLng = lng;
            await JSRuntime.InvokeVoidAsync("voltaMap.addMarker", lat, lng, true);
            selectingPickup = false; // Auto-switch
        }
        else
        {
            rideRequest.DropoffLocation = address;
            dropLat = lat; dropLng = lng;
            await JSRuntime.InvokeVoidAsync("voltaMap.addMarker", lat, lng, false);

            // Trigger Route Calculation
            await CheckRoute();
        }

        StateHasChanged();
    }

    // 🆕 4. CALCULATE ROUTE (Blue Line + ETA)
    private async Task CheckRoute()
    {
        if (pickLat.HasValue && dropLat.HasValue)
        {
            statusMessage = "🔄 Calculating path...";
            string result = await JSRuntime.InvokeAsync<string>("voltaMap.calculateRoute", pickLat, pickLng, dropLat, dropLng);

            if (!string.IsNullOrEmpty(result))
            {
                var parts = result.Split('|');
                etaText = parts[0];      // e.g. "15 mins"
                distanceText = parts[1]; // e.g. "5.2 km"
            }
            statusMessage = "";
            StateHasChanged();
        }
    }

    private async Task BookNow()
    {
        if (rideRequest.Price <= 0) { statusMessage = "❌ Price must be valid!"; return; }
        if (string.IsNullOrEmpty(rideRequest.PickupLocation)) { statusMessage = "❌ Enter Pickup!"; return; }

        statusMessage = "Submitting...";
        try
        {
            var token = await SessionStorage.GetItemAsync<string>("authToken");
            if (string.IsNullOrEmpty(token)) { statusMessage = "❌ Not logged in!"; return; }

            var msg = new HttpRequestMessage(HttpMethod.Post, "http://localhost:5002/ride/book");
            msg.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            msg.Content = JsonContent.Create(rideRequest);

            var res = await Http.SendAsync(msg);
            if (res.IsSuccessStatusCode)
            {
                statusMessage = "✅ Request Sent!";
                await Task.Delay(1000);
                Nav.NavigateTo("/");
            }
            else { statusMessage = "❌ Error: " + res.StatusCode; }
        }
        catch (Exception ex) { statusMessage = "Error: " + ex.Message; }
    }

    public class RideRequest { public string PickupLocation { get; set; } public string DropoffLocation { get; set; } public decimal Price { get; set; } }
}