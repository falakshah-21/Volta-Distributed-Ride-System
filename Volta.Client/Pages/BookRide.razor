@page "/book"
@inject HttpClient Http
@inject NavigationManager Nav
@using System.Net.Http.Json
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@using System.Net.Http.Headers
@inject IJSRuntime JSRuntime

<div class="volta-booking-wrapper">
    <main class="map-container">
        <div id="map"></div>
    </main>

    <aside class="booking-sidebar">
        <div class="sidebar-header">
            <button class="btn-back" @onclick='() => Nav.NavigateTo("/")'>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
            </button>
            <h2 class="fw-bold m-0">Book a Ride</h2>
        </div>

        <div class="sidebar-content">
            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="status-alert slide-down">
                    <span class="status-dot"></span> @statusMessage
                </div>
            }

            <div class="segmented-control mb-4">
                <button class="segment-btn @(selectingPickup ? "active pickup" : "")"
                        @onclick="() => selectingPickup = true">
                    Pickup
                </button>
                <button class="segment-btn @(!selectingPickup ? "active dropoff" : "")"
                        @onclick="() => selectingPickup = false">
                    Dropoff
                </button>
            </div>

            <div class="location-inputs mb-4">
                <div class="input-wrapper mb-3">
                    <div class="icon-indicator pickup-icon"></div>
                    <div class="flex-grow-1">
                        <label>Pickup Location</label>
                        <div class="search-box">
                            <input @bind="rideRequest.PickupLocation" placeholder="e.g. Lucky One Mall" />
                            <button class="btn-search" @onclick="() => SearchMap(true)">
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="input-line-connector"></div>

                <div class="input-wrapper">
                    <div class="icon-indicator dropoff-icon"></div>
                    <div class="flex-grow-1">
                        <label>Dropoff Location</label>
                        <div class="search-box">
                            <input @bind="rideRequest.DropoffLocation" placeholder="e.g. KIET Main Campus" />
                            <button class="btn-search" @onclick="() => SearchMap(false)">
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(etaText))
            {
                <div class="route-summary fade-in">
                    <div class="summary-item">
                        <svg class="text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <div>
                            <span class="d-block text-muted">Time</span>
                            <span class="fw-bold text-dark">@etaText</span>
                        </div>
                    </div>
                    <div class="summary-divider"></div>
                    <div class="summary-item">
                        <svg class="text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                        </svg>
                        <div>
                            <span class="d-block text-muted">Distance</span>
                            <span class="fw-bold text-dark">@distanceText</span>
                        </div>
                    </div>
                </div>
            }

            <div class="price-offer-section">
                <label>Your Offer</label>
                <div class="price-input-group">
                    <span class="currency">PKR</span>
                    <input @bind="rideRequest.Price" type="number" placeholder="0" class="price-input" />
                </div>
            </div>
        </div>

        <div class="sidebar-footer">
            <button class="btn-book-now" @onclick="BookNow">Confirm Ride</button>
        </div>
    </aside>
</div>

@code {
    private RideRequest rideRequest = new RideRequest();
    private string statusMessage = "";
    private bool selectingPickup = true;

    private double? pickLat, pickLng, dropLat, dropLng;
    private string etaText = "";
    private string distanceText = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var dotNetReference = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("voltaMap.initMap", "map", dotNetReference);
        }
    }

    private async Task SearchMap(bool isPickup)
    {
        string query = isPickup ? rideRequest.PickupLocation : rideRequest.DropoffLocation;
        if (string.IsNullOrEmpty(query)) return;

        statusMessage = "Searching...";

        string coords = await JSRuntime.InvokeAsync<string>("voltaMap.searchLocation", query, isPickup);

        if (!string.IsNullOrEmpty(coords))
        {
            var parts = coords.Split(',');
            if (isPickup) { pickLat = double.Parse(parts[0]); pickLng = double.Parse(parts[1]); }
            else { dropLat = double.Parse(parts[0]); dropLng = double.Parse(parts[1]); }

            await CheckRoute();
        }
        statusMessage = "";
    }

    [JSInvokable]
    public async Task OnMapClicked(double lat, double lng, string address)
    {
        if (selectingPickup)
        {
            rideRequest.PickupLocation = address;
            pickLat = lat; pickLng = lng;
            await JSRuntime.InvokeVoidAsync("voltaMap.addMarker", lat, lng, true);
            selectingPickup = false;
        }
        else
        {
            rideRequest.DropoffLocation = address;
            dropLat = lat; dropLng = lng;
            await JSRuntime.InvokeVoidAsync("voltaMap.addMarker", lat, lng, false);
            await CheckRoute();
        }
        StateHasChanged();
    }

    private async Task CheckRoute()
    {
        if (pickLat.HasValue && dropLat.HasValue)
        {
            statusMessage = "Calculating path...";
            string result = await JSRuntime.InvokeAsync<string>("voltaMap.calculateRoute", pickLat, pickLng, dropLat, dropLng);

            if (!string.IsNullOrEmpty(result))
            {
                var parts = result.Split('|');
                etaText = parts[0];
                distanceText = parts[1];
            }
            statusMessage = "";
            StateHasChanged();
        }
    }

    private async Task BookNow()
    {
        if (rideRequest.Price <= 0) { statusMessage = "Please enter a valid offer amount."; return; }
        if (string.IsNullOrEmpty(rideRequest.PickupLocation)) { statusMessage = "Please select a pickup location."; return; }

        statusMessage = "Connecting you to drivers...";
        try
        {
            var token = await SessionStorage.GetItemAsync<string>("authToken");
            if (string.IsNullOrEmpty(token)) { statusMessage = "Authentication required. Please log in."; return; }

            var msg = new HttpRequestMessage(HttpMethod.Post, "http://localhost:5002/ride/book");
            msg.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            msg.Content = JsonContent.Create(rideRequest);

            var res = await Http.SendAsync(msg);
            if (res.IsSuccessStatusCode)
            {
                statusMessage = "Ride requested successfully!";
                await Task.Delay(1500);
                Nav.NavigateTo("/");
            }
            else { statusMessage = "Error: " + res.StatusCode; }
        }
        catch (Exception ex) { statusMessage = "Connection failed. Please try again."; }
    }

    public class RideRequest
    {
        public string PickupLocation { get; set; } = ""; public string DropoffLocation { get; set; }
= ""; public decimal Price { get; set; }
    }
}