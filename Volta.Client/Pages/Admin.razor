@page "/admin"
@inject HttpClient Http
@inject NavigationManager Nav
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@inject IJSRuntime JSRuntime
@using System.Net.Http.Json
@using System.Net.Http.Headers

<div class="admin-dashboard">
    <header class="dashboard-header">
        <div class="header-content">
            <div class="title-group">
                <div class="icon-box">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                </div>
                <div>
                    <h1 class="page-title">Super Admin Panel</h1>
                    <p class="page-subtitle">Manage users, drivers, and system analytics</p>
                </div>
            </div>
            <button class="btn-glass" @onclick='() => Nav.NavigateTo("/")'>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Back to Dashboard
            </button>
        </div>
    </header>

   <nav class="custom-tabs">
        <button class="tab-btn @(activeTab == "pending" ? "active-tab" : "")" @onclick='() => SwitchTab("pending")'>
            Pending Drivers 
            @if (pendingDrivers.Count > 0) { <span class="badge-pulse">@pendingDrivers.Count</span> }
        </button>
        <button class="tab-btn @(activeTab == "users" ? "active-tab" : "")" @onclick='() => SwitchTab("users")'>All Users</button>
        <button class="tab-btn @(activeTab == "history" ? "active-tab" : "")" @onclick='() => SwitchTab("history")'>Global History</button>
        <button class="tab-btn @(activeTab == "admins" ? "active-tab" : "")" @onclick='() => SwitchTab("admins")'>Manage Admins</button>
    </nav>

    <main class="dashboard-card shadow-sm fade-in-up" key="@activeTab">
        
        @if (activeTab == "pending")
        {
            <div class="section-header">
                <h2>Verify New Drivers</h2>
                <p>Review and approve driver applications.</p>
            </div>

            @if (pendingDrivers.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-icon">🎉</div>
                    <h3>All caught up!</h3>
                    <p>There are no pending driver requests at the moment.</p>
                </div>
            }
            else
            {
                <div class="table-container">
                    <table class="modern-table">
                        <thead><tr><th>Applicant</th><th>Vehicle Details</th><th class="text-right">Actions</th></tr></thead>
                        <tbody>
                            @foreach (var d in pendingDrivers)
                            {
                                <tr>
                                    <td>
                                        <div class="user-cell">
                                            <div class="avatar bg-indigo">@d.FullName.FirstOrDefault()</div>
                                            <div class="user-info">
                                                <span class="fw-bold">@d.FullName</span>
                                                <span class="text-muted">@d.Username</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="vehicle-info">
                                            <span class="fw-medium">@d.CarName</span>
                                            <span class="plate-badge">@d.CarNumber</span>
                                        </div>
                                    </td>
                                    <td class="text-right action-cells">
                                        <button class="btn-action btn-success" @onclick="() => ApproveDriver(d.Id)">Approve</button>
                                        <button class="btn-action btn-danger-outline" @onclick="() => DeleteUser(d.Id)">Reject</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }

        @if (activeTab == "users")
        {
            <div class="section-header">
                <h2>Manage Active Users</h2>
                <p>View and manage all passengers and drivers on the platform.</p>
            </div>
            
            <div class="table-container">
                <table class="modern-table">
                    <thead><tr><th>User</th><th>Role</th><th>Vehicle (If Driver)</th><th class="text-right">Actions</th></tr></thead>
                    <tbody>
                        @foreach (var u in allUsers)
                        {
                            <tr>
                                <td>
                                    <div class="user-cell">
                                        <div class="avatar @(u.Role == "Driver" ? "bg-emerald" : "bg-slate")">@u.FullName.FirstOrDefault()</div>
                                        <div class="user-info">
                                            <span class="fw-bold">@u.FullName <small class="id-tag">#@u.Id</small></span>
                                            <span class="text-muted">@u.Username</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="role-badge @(u.Role == "Driver" ? "role-driver" : "role-passenger")">@u.Role</span>
                                </td>
                                <td>@(u.Role == "Driver" ? $"{u.CarName} ({u.CarNumber})" : "—")</td>
                                <td class="text-right">
                                    <button class="btn-icon-danger" title="Ban User" @onclick="() => DeleteUser(u.Id)">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path></svg>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (activeTab == "history")
        {
            <div class="section-header d-flex-between">
                <div>
                    <h2>System-Wide Ride History</h2>
                    <p>Real-time log of all platform transactions.</p>
                </div>
                <button class="btn-outline" @onclick="LoadHistory">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                    Refresh Data
                </button>
            </div>

            <div class="table-container">
                <table class="modern-table history-table">
                    <thead><tr><th>Ref</th><th>Passenger</th><th>Driver</th><th>Route</th><th>Price</th><th>Status</th></tr></thead>
                    <tbody>
                        @foreach (var r in globalHistory)
                        {
                            <tr>
                                <td class="text-muted small">#@r.Id</td>
                                <td class="fw-medium">@r.PassengerName</td>
                                <td class="fw-medium">@(r.DriverName ?? "—")</td>
                                <td>
                                    <div class="route-cell">
                                        <span class="dot-start"></span> @r.PickupLocation
                                        <svg class="route-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                                        <span class="dot-end"></span> @r.DropoffLocation
                                    </div>
                                </td>
                                <td class="fw-bold text-dark">Rs @r.Price</td>
                                <td>
                                    <span class="status-badge @(r.Status.ToLower())">@r.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (activeTab == "admins")
        {
            <div class="admin-grid">
                <div class="admin-list-card">
                    <h2>Existing Admins</h2>
                    <div class="admin-list">
                        @foreach (var admin in adminList)
                        {
                            <div class="admin-item">
                                <div class="user-cell">
                                    <div class="avatar bg-rose">@admin.FullName.FirstOrDefault()</div>
                                    <div class="user-info">
                                        <span class="fw-bold">@admin.FullName</span>
                                        <span class="text-muted">@admin.Username</span>
                                    </div>
                                </div>
                                <button class="btn-text-danger" @onclick="() => DeleteUser(admin.Id)">Remove</button>
                            </div>
                        }
                    </div>
                </div>

                <div class="admin-form-card">
                    <div class="form-header">
                        <div class="icon-circle"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path></svg></div>
                        <h3>Add New Admin</h3>
                    </div>
                    <div class="modern-form">
                        <div class="input-group">
                            <label>Full Name</label>
                            <input @bind="newAdmin.FullName" class="custom-input" placeholder="e.g. Jane Doe" />
                        </div>
                        <div class="input-group">
                            <label>Username</label>
                            <input @bind="newAdmin.Username" class="custom-input" placeholder="e.g. janedoe99" />
                        </div>
                        <div class="input-group">
                            <label>Password</label>
                            <input @bind="newAdmin.Password" type="password" class="custom-input" placeholder="••••••••" />
                        </div>
                        <button class="btn-primary-full" @onclick="CreateAdmin">Authorize Admin</button>
                    </div>
                </div>
            </div>
        }

    </main>
</div>

@code {
    private string activeTab = "pending";

    // Data Models
    private List<UserDto> pendingDrivers = new();
    private List<UserDto> allUsers = new();
    private List<UserDto> adminList = new();
    private List<RideHistoryDto> globalHistory = new();
    private RegisterDto newAdmin = new RegisterDto();

    protected override async Task OnInitializedAsync()
    {
        var role = await SessionStorage.GetItemAsync<string>("userRole");
        if (role != "Admin") { Nav.NavigateTo("/"); return; }

        await LoadData();
        await LoadHistory(); 
    }

    private void SwitchTab(string tabName)
    {
        // Adding a tiny delay or just re-rendering triggers the CSS fade animation
        activeTab = tabName;
        StateHasChanged();
    }

    private async Task LoadData()
    {
        try
        {
            pendingDrivers = await Http.GetFromJsonAsync<List<UserDto>>("http://localhost:5001/api/admin/pending-drivers") ?? new();
            adminList = await Http.GetFromJsonAsync<List<UserDto>>("http://localhost:5001/api/admin/list-admins") ?? new();
            allUsers = await Http.GetFromJsonAsync<List<UserDto>>("http://localhost:5001/api/admin/users") ?? new();
        }
        catch { /* Consider adding an error toast here in the future */ }
    }

    private async Task LoadHistory()
    {
        try
        {
            var token = await SessionStorage.GetItemAsync<string>("authToken");
            var request = new HttpRequestMessage(HttpMethod.Get, "http://localhost:5002/ride/history");
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                globalHistory = await response.Content.ReadFromJsonAsync<List<RideHistoryDto>>() ?? new();
            }
        }
        catch { }
    }

    private async Task ApproveDriver(int id)
    {
        var res = await Http.PutAsync($"http://localhost:5001/api/admin/approve/{id}", null);
        if (res.IsSuccessStatusCode) await LoadData();
    }

    private async Task DeleteUser(int id)
    {
        // UX Note: In a real enterprise app, replace this JS confirm with a custom Blazor Modal component.
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Are you absolutely sure you want to remove this user? This action cannot be undone.")) return;
        var res = await Http.DeleteAsync($"http://localhost:5001/api/admin/delete/{id}");
        if (res.IsSuccessStatusCode) await LoadData();
    }

    private async Task CreateAdmin()
    {
        var res = await Http.PostAsJsonAsync("http://localhost:5001/api/admin/create-admin", newAdmin);
        if (res.IsSuccessStatusCode)
        {
            newAdmin = new RegisterDto();
            await LoadData();
            // Optional: Replace alert with a sleek Toast notification library like Blazored.Toast
            await JSRuntime.InvokeVoidAsync("alert", "Administrator successfully authorized!");
        }
    }

    // DTOs
    public class UserDto { public int Id { get; set; } public string FullName { get; set; } = ""; public string Username { get; set; } = ""; public string Role { get; set; } = ""; public string CarName { get; set; } = ""; public string CarNumber { get; set; } = ""; }
    public class RegisterDto { public string FullName { get; set; } = ""; public string Username { get; set; } = ""; public string Password { get; set; } = ""; }
    public class RideHistoryDto { public int Id { get; set; } public string PassengerName { get; set; } = ""; public string DriverName { get; set; } = ""; public string PickupLocation { get; set; } = ""; public string DropoffLocation { get; set; } = ""; public decimal Price { get; set; } public string Status { get; set; } = ""; }
}