@inject Blazored.SessionStorage.ISessionStorageService SessionStorage

<div class="d-flex flex-column pt-3">

    <div class="nav-item">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
            <span class="oi oi-dashboard me-3"></span> Dashboard
        </NavLink>
    </div>

    @if (userRole == "Passenger")
    {
        <div class="nav-item">
            <NavLink class="nav-link" href="book">
                <span class="oi oi-map me-3"></span> Book a Ride
            </NavLink>
        </div>
    }

    <div class="nav-item">
        <NavLink class="nav-link" href="history">
            <span class="oi oi-clock me-3"></span> History
        </NavLink>
    </div>

    @if (userRole == "Admin")
    {
        <div class="nav-item mt-4 pt-3 border-top border-secondary">
            <NavLink class="nav-link text-warning" href="admin">
                <span class="oi oi-shield me-3"></span> Admin Panel
            </NavLink>
        </div>
    }
</div>

@code {
    private string userRole = "Guest";

    // --- CRITICAL FIX: Use OnAfterRenderAsync instead of OnInitializedAsync ---
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Only run this ONCE after the page has finished loading
        if (firstRender)
        {
            try
            {
                var role = await SessionStorage.GetItemAsync<string>("userRole");
                if (!string.IsNullOrEmpty(role))
                {
                    userRole = role;
                    StateHasChanged(); // Tell Blazor to update the menu NOW
                }
            }
            catch
            {
                // If storage fails, just stay as "Guest" - Do not crash!
            }
        }
    }
}