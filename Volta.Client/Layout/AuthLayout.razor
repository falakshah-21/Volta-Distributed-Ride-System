@inherits LayoutComponentBase

<div class="volta-auth-layout">

    <aside class="auth-brand-panel">
        <div class="glow-orb orb-1"></div>
        <div class="glow-orb orb-2"></div>

        <div class="brand-content">
            <div class="brand-logo-wrapper fade-in-up">
                <svg class="brand-logo" style="width: 48px; height: 48px; min-width: 48px;color:  #38bdf8;" fill="none"
                     stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
            </div>
            <h1 class="brand-title fade-in-up" style="animation-delay: 0.1s;">VOLTA</h1>
            <h3 class="brand-subtitle fade-in-up" style="animation-delay: 0.2s;">The Future of City Travel.</h3>

            <div class="brand-divider fade-in-up" style="animation-delay: 0.3s;"></div>

            <p class="brand-text fade-in-up" style="animation-delay: 0.4s;">
                Secure. Fast. Electric.<br>
                Join the network that moves at your speed.
            </p>
        </div>
    </aside>

    <main class="auth-form-panel">
        @Body
    </main>

</div>